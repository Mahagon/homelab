{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    "abandonments:recommended",
    "group:recommended",
    ":configMigration",
    ":pinDevDependencies",
    ":gitSignOff"
  ],
  "prCreation": "immediate",
  "automerge": false,
  "automergeType": "pr",
  "argocd": {
    "managerFilePatterns": [
      "/k8s/apps/.+/application\\.yaml$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/k8s/apps/.+/manifests/.+\\.yaml$/"
    ],
    "pinDigests": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/k8s/apps/home-assistant/manifests/home-assistant\\.yaml$/"
      ],
      "matchStrings": [
        "HACS_VERSION=\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "hacs/integration",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    }
  ]
}
