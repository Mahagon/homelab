{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    "abandonments:recommended",
    "group:recommended",
    ":configMigration",
    ":pinDevDependencies",
    ":gitSignOff"
  ],
  "prCreation": "immediate",
  "automerge": false,
  "automergeType": "pr",
  "argocd": {
    "managerFilePatterns": [
      "/k8s/apps/.+/application\\.yaml$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/k8s/apps/.+/manifests/.+\\.yaml$/"
    ]
  }
}
